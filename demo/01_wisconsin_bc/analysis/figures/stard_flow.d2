  shape: rectangle
  style.border-radius: 8
  style.fill: "#F3E5F5"
  style.stroke: "#CC79A7"
  style.font-size: 13
}

train: "Training set\n(n = 455)\nMalignant: 170 | Benign: 285" {
  shape: rectangle
  style.border-radius: 8
  style.fill: "#E8F5E9"
  style.stroke: "#009E73"
